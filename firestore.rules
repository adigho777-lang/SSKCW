rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.phone_number != null && 
         exists(/databases/$(database)/documents/admins/$(request.auth.token.phone_number))) ||
        (request.auth.token.email != null && 
         exists(/databases/$(database)/documents/admins/$(request.auth.token.email)))
      );
    }
    
    // Admins collection - only admins can read/write
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }
    
    // Products collection
    match /products/{productId} {
      allow read: if true; // Anyone can read products
      allow write: if isAdmin(); // Only admins can create/update/delete
    }
    
    // Orders collection
    match /orders/{orderId} {
      allow create: if true; // Anyone can create orders
      allow read, update, delete: if isAdmin(); // Only admins can manage orders
    }
    
    // Leads collection
    match /leads/{leadId} {
      allow create: if true; // Anyone can create leads
      allow read, delete: if isAdmin(); // Only admins can view/delete leads
    }
  }
}
